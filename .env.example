# Port the web server listens on (default 8081)
PORT=8081

# Optional: Euler Stream API key for signing requests (improves connection reliability).
# Get one at https://www.eulerstream.com/
API_KEY=

# Proxy for all TikTok traffic (got HTTP client + ws WebSocket).
# Required when the host can't reach TikTok directly (e.g. mainland China).
# Point it at your local proxy (Clash/Mihomo/V2Ray etc.), e.g. http://127.0.0.1:7897
PROXY=

# Optional: TikTok sessionid cookie. Allows connecting to streams that require login.
SESSIONID=

# Optional: enable per-IP connection/request rate limiting (set to any non-empty value)
ENABLE_RATE_LIMIT=

# --- Live host-speech transcription (local Whisper) ---
# Set to 0/false to disable the transcript column entirely.
ENABLE_TRANSCRIPTION=1
# Whisper model size: tiny | base | small | medium  (larger = more accurate, higher latency)
WHISPER_MODEL=small
# Spoken language code (e.g. en, ja, zh). Leave empty to auto-detect.
WHISPER_LANGUAGE=
# Compute backend: cpu | cuda
WHISPER_DEVICE=cpu
# ctranslate2 compute type: int8 (fast, low memory) | float16 | float32
WHISPER_COMPUTE=int8
# Max seconds of speech before forcing a transcript line (lower = lower latency)
WHISPER_MAX_SEG=4
# Beam size: 1 = fastest, higher = more accurate but slower
WHISPER_BEAM=1
# CPU threads for inference (default: physical cores). Raise/lower to tune throughput.
# WHISPER_CPU_THREADS=4

# Optional: Google reCAPTCHA v2 keys to gate connections from the browser
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
